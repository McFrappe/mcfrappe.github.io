---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="rgb(241, 241, 244)" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="rgb(23, 23, 26)" />
    <title>{title}</title>
</head>

<body>
    <div class="background--custom" aria-hidden="true"></div>

    <slot />
</body>

</html>

<style is:global>
:root {
    --link: #fff;
    --link-hover: rgb(210, 210, 210);
    --glass-radius: 30px;
    --glass-bg: rgba(32, 32, 36, 0.4);
    --glass-border: rgba(100, 116, 139, 0.28);
    --glass-blur: 16px;
    --glass-shadow-outer: 0 12px 40px rgba(2, 6, 23, 0.3);
    --glass-inset-tint: rgba(255, 255, 255, 0.06);
    --glass-inset-highlight: rgba(255, 255, 255, 0.1);
}

html {
    margin: 0;
}

*, *::before, *::after {
    box-sizing: border-box;
}

body {
    margin: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    font-family: monospace;
    font-size: 1.125rem;
    line-height: 1.55;
    color: #fff;
}

a {
    color: var(--link);
    transition: color 0.15s ease;
}

a:hover {
    color: var(--link-hover);
}

h1, h2, h3 {
    margin-top: 0;
    line-height: 1.25;
}

h2 {
    font-size: 1.65rem;
}

h3 {
    font-size: 1.3rem;
}

h4 {
    font-size: 1.1rem;
    margin: 0.35rem 0 0;
}

.background--custom {
    position: fixed;
    inset: 0;
    z-index: -3;
    pointer-events: none;
    overflow: hidden;
    isolation: isolate;
    background: linear-gradient(
        118deg,
        #0a0a0a 0%,
        #3d3d3d 28%,
        #a3a3a3 52%,
        #efefef 78%,
        #1f1f1f 100%
    );
    background-size: 320% 320%;
    animation: gradient-shift 14s ease-in-out alternate infinite;
}

.background--custom::before {
    content: '';
    position: absolute;
    inset: -35%;
    background:
        radial-gradient(ellipse 55% 45% at 22% 28%, rgba(255, 255, 255, 0.38) 0%, transparent 52%),
        radial-gradient(ellipse 50% 55% at 78% 72%, rgba(0, 0, 0, 0.55) 0%, transparent 50%),
        radial-gradient(ellipse 40% 40% at 55% 18%, rgba(200, 200, 200, 0.28) 0%, transparent 48%);
    filter: blur(64px);
    animation: blob-drift 22s ease-in-out infinite alternate;
}

.background--custom::after {
    content: '';
    position: absolute;
    inset: -10%;
    background-image:
        repeating-linear-gradient(
            105deg,
            rgba(255, 255, 255, 0.045) 0,
            rgba(255, 255, 255, 0.045) 1px,
            transparent 1px,
            transparent 72px
        ),
        repeating-linear-gradient(
            -18deg,
            rgba(0, 0, 0, 0.055) 0,
            rgba(0, 0, 0, 0.055) 1px,
            transparent 1px,
            transparent 96px
        ),
        radial-gradient(circle at 50% 50%, transparent 0%, rgba(0, 0, 0, 0.12) 100%);
    filter: blur(2.5px);
    opacity: 0.65;
    mix-blend-mode: overlay;
    animation: pattern-shift 28s linear infinite;
}

@keyframes gradient-shift {
    0% {
        background-position: 12% 20%;
    }
    100% {
        background-position: 88% 82%;
    }
}

@keyframes blob-drift {
    0% {
        transform: translate(-4%, -2%) rotate(-2deg) scale(1);
    }
    100% {
        transform: translate(6%, 5%) rotate(3deg) scale(1.06);
    }
}

@keyframes pattern-shift {
    to {
        transform: translate(-3%, 2%);
    }
}

@media (prefers-color-scheme: light) {
    .glass {
        --glass-bg: rgba(120, 120, 125, 0.22);
        --glass-border: rgba(100, 116, 139, 0.36);
        --glass-shadow-outer: 0 12px 36px rgba(2, 6, 23, 0.14);
        --glass-inset-tint: rgba(255, 255, 255, 0.1);
        --glass-inset-highlight: rgba(255, 255, 255, 0.18);
    }
}

@media (prefers-color-scheme: dark) {
    .glass {
        --glass-bg: rgba(18, 18, 22, 0.42);
        --glass-border: rgba(100, 116, 139, 0.26);
        --glass-shadow-outer: 0 12px 40px rgba(0, 0, 0, 0.45);
        --glass-inset-tint: rgba(255, 255, 255, 0.06);
        --glass-inset-highlight: rgba(255, 255, 255, 0.07);
    }
}

.glass {
    position: relative;
    width: 100%;
    border-radius: var(--glass-radius);
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur)) saturate(85%);
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(85%);
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow-outer),
        inset 0 0 120px var(--glass-inset-tint),
        inset 0 0 4px 2px var(--glass-inset-highlight);
    overflow: hidden;
}

.post {
    padding: 2rem;
    position: relative;
    z-index: 1;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.9);
}

.layout {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 100%;
    padding: 3rem 1rem;
}

.main-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 32rem;
    max-width: 100%;
}

.main-wrapper.padded {
    padding: 3rem 1rem;
}

.main-wrapper--wide {
    width: min(56rem, 100%);
}

.section {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-top: 2rem;
}

.section-title,
.section-intro {
    padding-left: 0.5rem;
    color: #fff;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.9);
}

.section-title {
    position: relative;
    z-index: 1;
    font-size: 1.65rem;
}

.section-intro {
    margin: -0.75rem 0 0;
    opacity: 0.92;
}

.project-date {
    font-size: 0.95rem;
    opacity: 0.6;
    margin: 0;
}

@media screen and (max-width: 600px) {
    .main-wrapper {
        width: 100%;
    }

    .layout {
        padding: 2rem 1rem;
    }
}
</style>
