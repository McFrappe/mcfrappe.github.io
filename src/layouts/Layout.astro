---
import { existsSync, readdirSync } from 'node:fs';
import path from 'node:path';

interface Props {
  title: string;
}

const { title } = Astro.props;

function firstPublicImageUrl(): string | null {
  const dir = path.join(process.cwd(), 'public', 'images');
  if (!existsSync(dir)) return null;
  const names = readdirSync(dir).filter((f) => /\.(jpe?g|png|webp|gif)$/i.test(f));
  names.sort();
  return names.length ? `/images/${names[0]}` : null;
}

const bgImageUrl = firstPublicImageUrl();
---

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="rgb(241, 241, 244)" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="rgb(23, 23, 26)" />
    <title>{title}</title>
</head>

<body>
    <!-- Background image (first image file in public/images/) -->
    <div
        class="bg-image"
        aria-hidden="true"
        style={bgImageUrl ? { '--bg-image': `url('${bgImageUrl}')` } : undefined}
    ></div>

    <slot />
</body>

</html>

<style is:global>
:root {
    --link:rgb(255, 255, 255);
    --link-hover:rgb(176, 255, 145);
    --bg-light: #f1f1f4;
    --bg-dark:  #17171a;
    --glass-radius: 30px;
    --glass-bg: rgba(24, 18, 38, 0.37);
    --glass-border: rgba(100, 116, 139, 0.28);
    --glass-blur: 16px;
    --glass-shadow-outer: 0 12px 40px rgba(2, 6, 23, 0.3);
    --glass-inset-tint: rgba(196, 183, 215, 0.09);
    --glass-inset-highlight: rgba(255, 255, 255, 0.1);
}

html {
    margin: 0;
}

*, *::before, *::after {
    box-sizing: border-box;
}

body {
    font-family: monospace;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 100vh;
    margin: 0;
    font-size: 1.125rem;
    line-height: 1.55;
}

h1, h2, h3 {
    margin-top: 0;
    line-height: 1.25;
}

h2 {
    font-size: 1.65rem;
}

h3 {
    font-size: 1.3rem;
}

h4 {
    font-size: 1.1rem;
    margin: 0.35rem 0 0;
}

/* ── Background image ──────────────────────────────────────── */
.bg-image {
    position: fixed;
    inset: 0;
    z-index: -3;
    background: var(--bg-image, none) center/cover no-repeat;
    pointer-events: none;
    opacity: 1;
}

/* ── Light mode ─────────────────────────────────────────────── */
@media (prefers-color-scheme: light) {
    body {
        background-color: var(--bg-light);
        color: #fff;
    }
    .bg-image {
        opacity: 1;
    }
    .glass {
        --glass-bg: rgba(138, 84, 219, 0.2);
        --glass-border: rgba(100, 116, 139, 0.36);
        --glass-shadow-outer: 0 12px 36px rgba(2, 6, 23, 0.14);
        --glass-inset-tint: rgba(196, 183, 215, 0.14);
        --glass-inset-highlight: rgba(255, 255, 255, 0.18);
    }
    a {
        color: var(--link);
        transition: color 0.15s ease;
    }
    a:hover {
        color: var(--link-hover);
    }
}

/* ── Dark mode ──────────────────────────────────────────────── */
@media (prefers-color-scheme: dark) {
    body {
        background-color: var(--bg-dark);
        color: #fff;
    }
    .bg-image {
        opacity: 1;
    }
    .glass {
        --glass-bg: rgba(10, 8, 18, 0.1);
        --glass-border: rgba(100, 116, 139, 0.26);
        --glass-shadow-outer: 0 12px 40px rgba(0, 0, 0, 0.45);
        --glass-inset-tint: rgba(196, 183, 215, 0.08);
        --glass-inset-highlight: rgba(255, 255, 255, 0.07);
    }
    a {
        color: var(--link);
        transition: color 0.15s ease;
    }
    a:hover {
        color: var(--link-hover);
    }
}

/* ── Glass cards (CSS glassmorphism only — no SVG displacement) ─ */
.glass {
    position: relative;
    width: 100%;
    border-radius: var(--glass-radius);
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur)) saturate(180%);
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(180%);
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow-outer),
        inset 0 0 120px var(--glass-inset-tint),
        inset 0 0 4px 2px var(--glass-inset-highlight);
    overflow: hidden;
}

.post {
    padding: 2rem;
    position: relative;
    z-index: 1;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.9);
}

/* ── Layout ─────────────────────────────────────────────────── */
.layout {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 100%;
    padding: 3rem 1rem;
}

.main-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 32rem;
    max-width: 100%;
}

.main-wrapper.padded {
    padding: 3rem 1rem;
}

.main-wrapper--wide {
    width: min(56rem, 100%);
}

/* ── Projects section ───────────────────────────────────────── */
.section {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-top: 2rem;
}

.section-title {
    position: relative;
    z-index: 1;
    padding-left: 0.5rem;
    color: #fff;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.9);
    font-size: 1.65rem;
}

.section-intro {
    margin: -0.75rem 0 0;
    padding-left: 0.5rem;
    color: #fff;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.9);
    opacity: 0.92;
}

.project-date {
    font-size: 0.95rem;
    opacity: 0.6;
    margin: 0;
}

/* ── Mobile ─────────────────────────────────────────────────── */
@media screen and (max-width: 600px) {
    .main-wrapper {
        width: 100%;
    }

    .layout {
        padding: 2rem 1rem;
    }
}
</style>
